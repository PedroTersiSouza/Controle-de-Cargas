<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1565C0"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚚 Controle de Cargas"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Carregando..."
                android:textColor="#BBDEFB"
                android:textSize="13sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Barra de busca e ordenação -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1976D2"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            android:paddingBottom="10dp"
            android:paddingTop="4dp"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/edtBusca"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:hint="🔍 Buscar produto ou categoria..."
                android:textColorHint="#90CAF9"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_busca"
                android:paddingStart="12dp"
                android:paddingEnd="8dp"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true"
                android:textSize="13sp" />

            <ImageButton
                android:id="@+id/btnOrdenar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#FFFFFF"
                android:layout_marginStart="4dp"
                android:contentDescription="Ordenar" />

        </LinearLayout>

        <!-- Botão dashboard -->
        <Button
            android:id="@+id/btnDashboard"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="📊 Ver Dashboard do Estoque"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#0288D1"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="4dp" />

        <!-- Mensagem vazia -->
        <TextView
            android:id="@+id/txtVazio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nenhum produto encontrado"
            android:textAlignment="center"
            android:textColor="#757575"
            android:textSize="16sp"
            android:padding="32dp"
            android:visibility="gone" />

        <!-- Lista -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="8dp"
            android:clipToPadding="false"
            android:paddingBottom="72dp" />

    </LinearLayout>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdicionar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#4CAF50"
        android:contentDescription="Novo Produto" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
